# Server-side (Vercel project env vars)
SUPABASE_URL=https://kanderhmsvibtduhpsir.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
RESEND_API_KEY=re_xxx
FREE_PDF_FROM_EMAIL=hello@atlaslionclaw.com
# url or attachment (recommended: url with one-time secure token)
FREE_PDF_DELIVERY_MODE=url
PUBLIC_BASE_URL=https://atlaslionclaw.com
FREE_PDF_TOKEN_TTL_MINUTES=15

# used when FREE_PDF_DELIVERY_MODE=url (fallback only)
FREE_PDF_URL=https://atlaslionclaw.com/free/openclaw-quick-fix-guide.pdf

# used when FREE_PDF_DELIVERY_MODE=attachment
FREE_PDF_ATTACHMENT_PATH=protected-assets/free/openclaw-quick-fix-guide.pdf
FREE_PDF_ATTACHMENT_FILENAME=openclaw-quick-fix-guide.pdf
