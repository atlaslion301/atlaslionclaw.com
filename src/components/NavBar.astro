---
const { links = [] } = Astro.props;
---
<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/" aria-label="AtlasLionClaw home">
      <img src="/assets/atlaslionclaw-logo.png" alt="AtlasLionClaw" />
    </a>
    <nav>
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>