---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
---
<BaseLayout title="AtlasLionClaw Blog | OpenClaw + AI News" description="OpenClaw setup guides, troubleshooting posts, and AI news for builders.">
  <NavBar links={[{ href: '/', label: 'Home' }]} />

  <main class="container section">
    <h1>OpenClaw + AI Blog</h1>
    <p class="lead">News, updates, setup tutorials, and field-tested fixes.</p>

    <div class="grid two">
      <a class="post-card" href="/blog/openclaw-setup-checklist/">
        <h4>OpenClaw Setup Checklist (2026)</h4>
        <p>Clean setup path with validation checkpoints.</p>
      </a>
      <a class="post-card" href="/blog/openclaw-discord-fixes/">
        <h4>Top Discord Integration Fixes</h4>
        <p>Pairing and allowlist issues solved quickly.</p>
      </a>
      <a class="post-card" href="/blog/openclaw-ai-news-roundup/">
        <h4>OpenClaw + AI News Roundup</h4>
        <p>Weekly updates that impact operators and builders.</p>
      </a>
    </div>
  </main>
</BaseLayout>