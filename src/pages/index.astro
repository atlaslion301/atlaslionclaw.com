---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import Accordion from '../components/Accordion.astro';

const spotlightItems = [
  {
    question: 'AI Skills Library',
    answer: 'Explore tool-specific pages for OpenClaw, Claude Code, and coding workflows.',
    href: '/ai-skills/'
  },
  {
    question: 'Use Cases Library',
    answer: 'See outcome-focused workflows for operations, automation, and team execution.',
    href: '/use-cases/'
  },
  {
    question: 'OpenClaw Skill Page',
    answer: 'Learn where OpenClaw shines: orchestration, memory, channel ops, and reliability.',
    href: '/ai-skills/openclaw/'
  },
  {
    question: 'Claude Code Skill Page',
    answer: 'Understand when to use Claude Code for implementation, refactors, and review loops.',
    href: '/ai-skills/claude-code/'
  }
];

const quickAnswerItems = [
  {
    question: 'What is the fastest reliable setup path?',
    answer:
      'Install OpenClaw, configure channel tokens securely, start gateway, complete pairing, and run an end-to-end message test before opening access to a wider team.'
  },
  {
    question: 'How do you prevent most failures?',
    answer:
      'Use a preflight checklist, keep allowlists explicit, and validate one integration at a time. Start with these guides: <a href="/blog/openclaw-setup-checklist/">Setup Checklist</a>, <a href="/blog/openclaw-discord-fixes/">Discord Fixes</a>, and <a href="/blog/openclaw-reliable-scheduled-workflows/">Reliable Scheduled Workflows</a>.'
  }
];

const faqItems = [
  {
    question: 'What does AtlasLionClaw help with?',
    answer:
      'AtlasLionClaw helps operators deploy and troubleshoot OpenClaw with production-minded checklists, hardening guidance, and repeatable workflow patterns.'
  },
  {
    question: 'Is the free PDF enough for first deployment?',
    answer:
      'Yes. The free guide covers first deployment basics and top failure fixes. The paid playbook goes deeper on hardening and multi-person operations.'
  },
  {
    question: 'Which guide should I read first?',
    answer:
      'Start with the <a href="/blog/openclaw-setup-checklist/">OpenClaw Setup Checklist</a>, then continue with <a href="/blog/openclaw-security-hardening-2026/">Security Hardening</a> and <a href="/blog/telegram-vs-discord-openclaw-2026/">Telegram vs Discord</a> for architecture decisions.'
  }
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'OpenClaw Setup & Troubleshooting Guide (Free + Paid Playbook)',
  url: 'https://atlaslionclaw.com/',
  description: 'Fix OpenClaw setup and troubleshooting issues faster. Download the free Quick Fix PDF and join the advanced Operator Playbook waitlist.',
  mainEntity: {
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is AtlasLionClaw?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'AtlasLionClaw publishes OpenClaw setup guides, troubleshooting checklists, and operator playbooks so teams can run agents more reliably in production.'
        }
      },
      {
        '@type': 'Question',
        name: 'Who should use the free OpenClaw Quick Fix Guide?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The free guide is designed for builders who want a fast install-to-pairing workflow and fixes for common Discord, Telegram, gateway, and configuration issues.'
        }
      },
      {
        '@type': 'Question',
        name: 'When should I use the Operator Playbook?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Use the Operator Playbook when you are moving from one-off demos to repeatable production workflows with stronger hardening, monitoring, and release validation.'
        }
      }
    ]
  }
};
---
<BaseLayout title="OpenClaw Setup & Troubleshooting Guide (Free + Paid Playbook)" description="Fix OpenClaw setup and troubleshooting issues faster. Download the free Quick Fix PDF and join the advanced Operator Playbook waitlist." schema={pageSchema}>
  <NavBar links={[{ href: '/blog/', label: 'Blog' }, { href: '/ai-skills/', label: 'AI Skills' }, { href: '/use-cases/', label: 'Use Cases' }, { href: '#free', label: 'Free PDF' }, { href: '#paid', label: 'Paid Playbook' }]} />

  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">OPENCLAW OPERATOR GUIDES</p>
        <h1>Elegant setup and troubleshooting guides for OpenClaw builders.</h1>
        <p class="lead">Ship faster, debug less. Preview free teasers, then login + pay to unlock full Markdown bundles for AI Skills and Use Cases.</p>
        <div class="cta-row">
          <a href="#free" class="btn">View Teasers</a>
          <a href="#paid" class="btn btn-ghost">Login + Unlock Bundles</a>
        </div>
      </div>
      <aside class="hero-card">
        <h3>What’s covered</h3>
        <ul>
          <li>Setup quickstart</li>
          <li>Discord + Telegram fixes</li>
          <li>Gateway + config errors</li>
          <li>Security hardening basics</li>
        </ul>
      </aside>
    </div>
  </section>

  <main class="container">
    <section class="section" id="free">
      <h2>Teasers + Premium Markdown Downloads</h2>
      <div class="grid two">
        <article class="card">
          <p class="tag">FREE TEASERS</p>
          <h3>Preview Skills + Use Cases</h3>
          <ul>
            <li>OpenClaw + Claude Code teaser pages</li>
            <li>Outcome-focused use case previews</li>
            <li>Sample markdown teaser files</li>
          </ul>
          <div class="cta-row" style="margin-top: 12px;">
            <a class="btn btn-ghost" href="/ai-skills/">Explore AI Skills Teasers</a>
            <a class="btn btn-ghost" href="/use-cases/">Explore Use Cases Teasers</a>
          </div>
          <p class="note" id="freeMsg">Teasers are free. Full markdown bundles require login + payment.</p>
        </article>

        <article class="card" id="paid">
          <p class="tag">PREMIUM</p>
          <h3>Markdown Bundles: Skills + Use Cases</h3>
          <ul>
            <li>Downloadable <code>.md</code> AI Skills bundle</li>
            <li>Downloadable <code>.md</code> Use Cases bundle</li>
            <li>Secure one-time delivery after checkout</li>
          </ul>
          <form class="form" id="paidForm">
            <label>Account email</label>
            <input type="email" name="email" required placeholder="login required" />
            <div class="hp-wrap" aria-hidden="true">
              <label>Leave this field empty</label>
              <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-dark">Login + Pay to Download</button>
          </form>
          <p class="note" id="paidMsg">You must be logged in before checkout. We verify login identity before payment.</p>
        </article>
      </div>
    </section>

    <section class="section">
      <h2>Latest from the blog</h2>
      <div class="grid three">
        <a class="post-card" href="/blog/scaling-openclaw-enterprise-fleet/">
          <h4>Scaling OpenClaw: From Personal Assistant to Enterprise Fleet</h4>
          <p>Transition from a single agent to a reliable enterprise fleet.</p>
        </a>
        <a class="post-card" href="/blog/securing-autonomous-agents-openclaw/">
          <h4>Securing Your Autonomous Agents</h4>
          <p>A guide to OpenClaw permissions and host safety.</p>
        </a>
        <a class="post-card" href="/blog/from-chat-to-action-ai-workflows/">
          <h4>From Chat to Action</h4>
          <p>How AI workflows move from messages to real operations.</p>
        </a>
        <a class="post-card" href="/blog/rise-of-ai-operations-as-a-real-job/">
          <h4>The Rise of AI Operations as a Real Job</h4>
          <p>Why AI Ops is becoming a real function, not a side hobby.</p>
        </a>
        <a class="post-card" href="/blog/what-breaks-in-ai-agent-systems/">
          <h4>What Actually Breaks in AI Agent Systems</h4>
          <p>Battle-tested failure patterns and how to operate around them.</p>
        </a>
      </div>
    </section>

    <section class="section">
      <h2>AI Skills + Use Cases</h2>
      <div class="grid two">
        {spotlightItems.map((item) => (
          <a class="post-card" href={item.href}>
            <h4>{item.question}</h4>
            <p>{item.answer}</p>
          </a>
        ))}
      </div>
      <div style="margin-top: 16px; display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/ai-skills/" class="btn btn-ghost">Browse AI Skills</a>
        <a href="/use-cases/" class="btn btn-ghost">Browse Use Cases</a>
      </div>
    </section>

    <section class="section">
      <h2>OpenClaw setup: quick answer</h2>
      <Accordion items={quickAnswerItems} idPrefix="home-quick-answer" />
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <Accordion items={faqItems} idPrefix="home-faq" />
    </section>
  </main>

  <script is:inline>
    window.SUPABASE_URL = 'https://kanderhmsvibtduhpsir.supabase.co';
    window.SUPABASE_PUBLISHABLE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImthbmRlcmhtc3ZpYnRkdWhwc2lyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwOTQ1NDQsImV4cCI6MjA4ODY3MDU0NH0.wlJq3rNNwyuqCiTbUd2SKk-sDgFFl-wPmfI2m4hLQIk';
  </script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/script.js" defer></script>
</BaseLayout>