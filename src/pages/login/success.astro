---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
---
<BaseLayout title="Login Success" description="You are signed in. Continue to checkout to unlock downloads.">
  <NavBar links={[{ href: '/', label: 'Home' }, { href: '/ai-skills/', label: 'AI Skills' }, { href: '/use-cases/', label: 'Use Cases' }]} />

  <main class="container">
    <section class="content-shell" style="max-width: 640px; margin: 0 auto;">
      <h1>Logged in</h1>
      <p class="lead">You’re signed in. Return to checkout to unlock your downloads.</p>
      <p class="note" id="sessionMsg"></p>
      <div class="cta-row" style="margin-top: 12px;">
        <a class="btn" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/#paid">Go to paid playbook</a>
      </div>
    </section>
  </main>

  <script is:inline>
    const sessionMsg = document.getElementById('sessionMsg');
    const SUPABASE_URL = 'https://kanderhmsvibtduhpsir.supabase.co';
    const SUPABASE_PUBLISHABLE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImthbmRlcmhtc3ZpYnRkdWhwc2lyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwOTQ1NDQsImV4cCI6MjA4ODY3MDU0NH0.wlJq3rNNwyuqCiTbUd2SKk-sDgFFl-wPmfI2m4hLQIk';

    async function getSupabaseClient() {
      if (!SUPABASE_URL || !SUPABASE_PUBLISHABLE_KEY) return null;
      if (window.supabase?.createClient) {
        return window.supabase.createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY);
      }
      try {
        const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm');
        return createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY);
      } catch (err) {
        console.error('Supabase load failed', err);
        return null;
      }
    }

    getSupabaseClient().then((client) => {
      if (!client) return;
      client.auth.getSession().then(({ data, error }) => {
        if (error) return;
        const email = data?.session?.user?.email;
        if (email) {
          sessionMsg.textContent = `Signed in as ${email}.`;
        }
      });
    });
  </script>
</BaseLayout>
